3. เตรียม Server 1 (Pre-Installation)
3.1 อัปเดต OS และติดตั้ง Package พื้นฐาน
# อัปเดต package list และ upgrade
sudo apt-get update && sudo apt-get upgrade -y

# ติดตั้ง tools ที่จำเป็น
sudo apt-get install -y curl wget git vim net-tools \
  apt-transport-https ca-certificates gnupg \
  lsb-release software-properties-common build-essential

3.2 ปิด Swap — สำคัญมาก!
Kubernetes บังคับให้ปิด Swap เพื่อให้ schedule resource ได้แม่นยำ
sudo swapoff -a
sudo sed -i '/ swap / s/^\(.*\)$/#\1/g' /etc/fstab
free -h   # ต้องเห็น Swap: 0B 0B 0B

3.3 ตั้งค่า Kernel สำหรับ Kubernetes
cat <<EOF | sudo tee /etc/modules-load.d/k8s.conf
overlay
br_netfilter
EOF
sudo modprobe overlay && sudo modprobe br_netfilter

cat <<EOF | sudo tee /etc/sysctl.d/k8s.conf
net.bridge.bridge-nf-call-iptables  = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward                 = 1
EOF
sudo sysctl --system
lsmod | grep -E 'br_netfilter|overlay'

3.4 กำหนด Hostname
sudo hostnamectl set-hostname open5gs-master
echo '127.0.0.1   open5gs-master' | sudo tee -a /etc/hosts
echo '10.162.0.1 open5gs-master' | sudo tee -a /etc/hosts
echo '10.162.0.2 oai-worker'    | sudo tee -a /etc/hosts
ip addr show | grep 'inet ' | grep -v '127.0.0.1'
 
4. ติดตั้ง Container Runtime (containerd)
4.1 ติดตั้ง containerd
sudo install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | \
  sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg
sudo chmod a+r /etc/apt/keyrings/docker.gpg

echo "deb [arch=$(dpkg --print-architecture) \
  signed-by=/etc/apt/keyrings/docker.gpg] \
  https://download.docker.com/linux/ubuntu \
  $(. /etc/os-release && echo $VERSION_CODENAME) stable" | \
  sudo tee /etc/apt/sources.list.d/docker.list > /dev/null

sudo apt-get update
sudo apt-get install -y containerd.io

4.2 ตั้งค่า containerd (ห้ามข้ามขั้นตอนนี้!)
⚠️  SystemdCgroup = true คือการตั้งค่าที่สำคัญที่สุด — ถ้าลืมจะทำให้ Pod ไม่ start และ Node จะ NotReady ตลอดเวลา

sudo mkdir -p /etc/containerd
containerd config default | sudo tee /etc/containerd/config.toml
sudo sed -i 's/SystemdCgroup = false/SystemdCgroup = true/g' \
  /etc/containerd/config.toml
grep 'SystemdCgroup' /etc/containerd/config.toml   # ต้องเห็น = true
sudo systemctl restart containerd
sudo systemctl enable containerd
sudo systemctl status containerd
 
5. ติดตั้ง Kubernetes (kubeadm, kubelet, kubectl)
คำสั่ง	หน้าที่
kubeadm	ตั้งค่า Kubernetes cluster (ใช้ครั้งแรกครั้งเดียว)
kubelet	agent ที่ทำงานอยู่ตลอดเวลา — คุมการทำงานของ Pod
kubectl	เครื่องมือ command line สำหรับสั่งงาน Kubernetes

5.1 เพิ่ม Kubernetes Repository
curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.28/deb/Release.key | \
  sudo gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg

echo 'deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] \
  https://pkgs.k8s.io/core:/stable:/v1.28/deb/ /' | \
  sudo tee /etc/apt/sources.list.d/kubernetes.list

sudo apt-get update

5.2 ติดตั้งและ Lock Version
sudo apt-get install -y kubelet kubeadm kubectl
sudo apt-mark hold kubelet kubeadm kubectl
kubeadm version && kubectl version --client

5.3 สร้าง Kubernetes Cluster (Master Node)
⚠️  แทน 10.162.0.1 ด้วย IP จริงของ Server 1 ถ้า IP ต่างกัน

sudo kubeadm init \
  --apiserver-advertise-address=10.162.0.1 \
  --pod-network-cidr=10.244.0.0/16 \
  --cri-socket=unix:///var/run/containerd/containerd.sock

# ถ้าสำเร็จจะเห็น:
# Your Kubernetes control-plane has initialized successfully!

💡  สำคัญ! บันทึก 'kubeadm join ...' command ที่ปรากฏเอาไว้ — จะใช้ใน Section 12 เพื่อ join Server 2 เข้า cluster

5.4 ตั้งค่า kubectl
mkdir -p $HOME/.kube
sudo cp -i /etc/kubernetes/admin.conf $HOME/.kube/config
sudo chown $(id -u):$(id -g) $HOME/.kube/config
kubectl get nodes   # Node จะ NotReady จนกว่าติดตั้ง CNI

5.5 อนุญาตให้ Master Node รัน Pod ได้
เนื่องจาก Open5GS รันบน Master Node ต้องลบ taint ออก:
kubectl taint nodes --all node-role.kubernetes.io/control-plane-
kubectl describe node open5gs-master | grep Taint   # ต้องไม่มี Taint แล้ว
 
6. ติดตั้ง CNI Plugin (Flannel)
kubectl apply -f https://github.com/flannelio/flannel/releases/latest/download/kube-flannel.yml
kubectl get pods -n kube-flannel -w   # รอจนเห็น Running แล้ว Ctrl+C
kubectl get nodes                     # ต้องเป็น Ready

⚠️  ถ้า Node ยังเป็น NotReady หลัง 5 นาที ให้ตรวจสอบ: sudo systemctl status kubelet

7. ติดตั้ง Helm
Helm คือ App Store สำหรับ Kubernetes ช่วยให้ติดตั้ง Open5GS ได้ง่ายด้วยคำสั่งเดียว
curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
helm version   # ควรเห็น version: v3.x.x

8. ติดตั้ง gtp5g Kernel Module
gtp5g คือ Kernel module ที่ให้ Linux รองรับ GTP-U tunnel ซึ่ง UPF ใช้ส่ง data packet ของ 5G — ถ้าไม่มีตัวนี้ UPF จะ crash
sudo apt-get install -y linux-headers-$(uname -r) gcc make git
git clone https://github.com/free5gc/gtp5g.git
cd gtp5g && make && sudo make install
sudo modprobe gtp5g
echo 'gtp5g' | sudo tee -a /etc/modules-load.d/gtp5g.conf
lsmod | grep gtp5g   # ต้องเห็น gtp5g
cd ..
 
9. Deploy Open5GS ด้วย Helm Chart
9.1 เพิ่ม Helm Repository และสร้าง Namespace
helm repo add open5gs https://gradiant.github.io/5g-charts/
helm repo update
kubectl create namespace open5gs
helm search repo open5gs

9.2 สร้างไฟล์ค่าตั้งค่า (values.yaml)
⚠️  UE Subnet เปลี่ยนเป็น 10.45.0.0/16 แล้ว — ห้ามใช้ 10.45.0.0/16 อีกต่อไป

cat <<'EOF' > open5gs-values.yaml
# Open5GS Configuration — Lab บพข. v2.1
# MCC=001, MNC=01, IP=10.162.0.1, UE Subnet: 10.45.0.0/16

mongodb:
  enabled: true
  persistence:
    enabled: true
    size: 10Gi

amf:
  enabled: true
  service:
    ngap:
      type: NodePort
      nodePort: 38412
  config:
    amf:
      plmn_support:
        - plmn_id:
            mcc: "001"
            mnc: "01"
          s_nssai:
            - sst: 1
              sd: '0xffffff'
      network_name:
        full: Open5GS-Lab
        short: O5GS
      amf_name: Open5GS-AMF0

smf:
  enabled: true
  config:
    smf:
      subnet:
        - addr: 10.45.0.1/16   # เปลี่ยนจาก 10.45.0.1/16
          dnn: internet

upf:
  enabled: true
  service:
    gtpu:
      type: NodePort
      nodePort: 32152
  config:
    upf:
      subnet:
        - addr: 10.45.0.1/16   # เปลี่ยนจาก 10.45.0.1/16
          dnn: internet

webui:
  enabled: true
  service:
    type: NodePort
    nodePort: 30080

nrf:  { enabled: true }
ausf: { enabled: true }
udm:  { enabled: true }
udr:  { enabled: true }
pcf:  { enabled: true }
bsf:  { enabled: true }
nssf: { enabled: true }
EOF

9.3 Deploy Open5GS
helm install open5gs open5gs/open5gs \
  --namespace open5gs \
  -f open5gs-values.yaml

kubectl get pods -n open5gs -w   # รอจนทุก Pod Running แล้ว Ctrl+C

💡  รอจนกว่าทุก Pod เป็น Running ก่อนทำขั้นตอนถัดไป

9.4 ตรวจสอบการ Deploy
kubectl get pods -n open5gs
kubectl get svc  -n open5gs
kubectl logs -n open5gs -l app=open5gs-amf --tail=20
kubectl logs -n open5gs -l app=open5gs-upf --tail=20
 
10. ตั้งค่า NAT สำหรับ UPF
UE จะได้รับ IP ในช่วง 10.45.0.0/16 จาก UPF แต่ต้องการออก internet ผ่าน IP จริงของ Server ต้องตั้งค่า NAT ก่อน
# หา network interface หลัก เช่น eth0, ens3, enp0s3
ip route | grep default

# เปิด IP Forwarding
echo 'net.ipv4.ip_forward = 1' | sudo tee -a /etc/sysctl.conf
sudo sysctl -p

# ตั้งค่า NAT — แทน eth0 ด้วย interface จริง
sudo iptables -t nat -A POSTROUTING -s 10.45.0.0/16 -o eth0 -j MASQUERADE

# บันทึก rules ให้คงอยู่หลัง reboot
sudo apt-get install -y iptables-persistent
sudo netfilter-persistent save

# ตรวจสอบ
sudo iptables -t nat -L POSTROUTING -v

