  sudo tee /etc/apt/sources.list.d/kubernetes.list

sudo apt-get update
sudo apt-get install -y kubelet kubeadm kubectl
sudo apt-mark hold kubelet kubeadm kubectl

12.8 Join Kubernetes Cluster
⚠️  ใช้ 'kubeadm join ...' command ที่ได้จาก Section 5.3 บน Server 1 — ห้ามใช้ตัวอย่างด้านล่างโดยตรง token และ hash จะแตกต่างกัน

# รัน command ที่ได้จาก Server 1 (Section 5.3) ตัวอย่าง:
sudo kubeadm join 10.162.0.1:6443 \
  --token <YOUR_TOKEN> \
  --discovery-token-ca-cert-hash sha256:<YOUR_HASH>

# ถ้า token หมดอายุ ให้ regenerate บน Server 1:
# kubeadm token create --print-join-command

12.9 ตรวจสอบการ Join (รันบน Server 1)
kubectl get nodes
# ต้องเห็น:
# NAME              STATUS   ROLES           AGE   VERSION
# open5gs-master    Ready    control-plane   Xm    v1.28.x
# oai-worker        Ready    <none>          Xm    v1.28.x

💡  ถ้า oai-worker แสดง Ready แสดงว่า join สำเร็จแล้ว ถ้า NotReady รอสัก 1-2 นาที หรือตรวจสอบ containerd บน Server 2
 
13. Label Worker Node สำหรับ OAI
กำหนด label ให้ Node เพื่อให้ OAI Pod ถูก schedule บน Server 2 โดยเฉพาะ — รันบน Server 1:
kubectl label node oai-worker oai-gnb=enabled
kubectl label node oai-worker node-type=ran
kubectl get nodes --show-labels | grep oai-worker

14. สร้าง OAI ConfigMap สำหรับ Kubernetes
14.1 ใช้ OAI Official Docker Image
OAI มี official Docker image พร้อมใช้งาน ไม่จำเป็นต้อง build เอง สำหรับ simulation mode:
# Official image: oaisoftwarealliance/oai-gnb
# Tag ที่ stable: develop หรือ 2024.w51

14.2 สร้าง Namespace และ ConfigMap — รันบน Server 1
kubectl create namespace oai

cat <<'EOF' > oai-gnb-configmap.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: oai-gnb-config
  namespace: oai
data:
  gnb.conf: |
    Active_gNBs = ( "oai-gnb" );
    Asn1_verbosity = "none";
    gNBs = (
      {
        GNB_ID   = 0xe00;
        gNB_name = "oai-gnb";
        plmn_list = (
          { mcc = 001; mnc = 01; mnc_length = 2;
            snssaiList = ( { sst = 1; sd = 0xffffff; } );
          }
        );
        tracking_area_code = 1;
        nr_cellid = 12345678L;
        amf_ip_address = (
          { ipv4 = "10.162.0.1";
            active = "yes"; preference = "ipv4"; }
        );
        NETWORK_INTERFACES : {
          GNB_IPV4_ADDRESS_FOR_NG_AMF = "10.162.0.2";
          GNB_IPV4_ADDRESS_FOR_NGU    = "10.162.0.2";
          GNB_PORT_FOR_S1U            = 2152;
        };
        servingCellConfigCommon = (
          { physCellId = 0;
            absoluteFrequencySSB = 641272;
            dl_frequencyBand = 78;
            dl_absoluteFrequencyPointA = 640008;
            dl_carrierBandwidth = 106; dl_subcarrierSpacing = 1;
            ul_frequencyBand = 78;
            ul_absoluteFrequencyPointA = 640008;
            ul_carrierBandwidth = 106; ul_subcarrierSpacing = 1;
          }
        );
      }
    );
    security = {
      preferred_integrity_algorithm = [ "nia2", "nia0" ];
      preferred_ciphering_algorithm = [ "nea0", "nea2" ];
    };
EOF
kubectl apply -f oai-gnb-configmap.yaml
 
15. Deploy OAI gNB บน Worker Node
15.1 สร้าง Deployment
cat <<'EOF' > oai-gnb-deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: oai-gnb
  namespace: oai
spec:
  replicas: 1
  selector:
    matchLabels:
      app: oai-gnb
  template:
    metadata:
      labels:
        app: oai-gnb
    spec:
      nodeSelector:
        oai-gnb: "enabled"      # รันบน Worker Node (Server 2)
      hostNetwork: true          # ใช้ IP ของ host สำหรับ N2/N3
      containers:
        - name: oai-gnb
          image: oaisoftwarealliance/oai-gnb:develop
          imagePullPolicy: IfNotPresent
          securityContext:
            privileged: true
          command:
            - /opt/oai-gnb/bin/nr-softmodem
          args:
            - -O
            - /opt/oai-gnb/etc/gnb.conf
            - --sa
            - --rfsim
            - --log_config.global_log_options
            - level,nocolor,time
          volumeMounts:
            - name: gnb-config
              mountPath: /opt/oai-gnb/etc/gnb.conf
              subPath: gnb.conf
      volumes:
        - name: gnb-config
          configMap:
            name: oai-gnb-config
EOF
kubectl apply -f oai-gnb-deployment.yaml

15.2 ตรวจสอบการ Deploy OAI gNB
kubectl get pods -n oai -w           # รอจนเห็น Running
kubectl logs -n oai -l app=oai-gnb -f --tail=50   # ต้องเห็น 'NG connection up'
kubectl get pods -n oai -o wide       # คอลัมน์ NODE ต้องเป็น oai-worker

💡  ถ้าเห็น 'NG connection up' และ 'Registration with AMF' ใน log — แสดงว่า OAI เชื่อมต่อกับ Open5GS สำเร็จ

16. Deploy NR-UE Simulator บน Kubernetes
cat <<'EOF' > oai-ue-deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: oai-nr-ue
  namespace: oai
spec:
  replicas: 1
  selector:
    matchLabels:
      app: oai-nr-ue
  template:
    metadata:
      labels:
        app: oai-nr-ue
    spec:
      nodeSelector:
        oai-gnb: "enabled"
      hostNetwork: true
      containers:
        - name: oai-nr-ue
          image: oaisoftwarealliance/oai-nr-ue:develop
          imagePullPolicy: IfNotPresent
          securityContext:
            privileged: true
          command: ["/opt/oai-nr-ue/bin/nr-uesoftmodem"]
          args:
            - "-r"
            - "106"
            - "--numerology"
            - "1"
            - "--band"
            - "78"
            - "-C"
            - "3619200000"
            - "--rfsim"
            - "--sa"
            - "--uicc0.imsi"
            - "001010000000001"
            - "--uicc0.nssai_sst"
            - "1"
            - "--uicc0.nssai_sd"
            - "0xffffff"
            - "--uicc0.key"
            - "465B5CE8B199B49FAA5F0A2EE238A6BC"
            - "--uicc0.opc"
            - "E8ED289DEBA952E4283B54E88E6183CA"
EOF
kubectl apply -f oai-ue-deployment.yaml
kubectl get pods -n oai -w

