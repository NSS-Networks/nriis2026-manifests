logger:
  level: info

global:
  max:

nssf:
  sbi:
    server:
    - dev: eth0
      port: 7777
    client:
      nrf:
      - uri: http://open5gs-nrf-sbi:7777
      nsi:
      - uri: http://open5gs-nrf-sbi:7777
        s_nssai:
          sst: 1
      - uri: http://open5gs-nrf-sbi:7777
        s_nssai:
          sst: 1
          sd: 000000
