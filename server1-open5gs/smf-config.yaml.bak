logger:
  level: info

global:

smf:
  sbi:
    server:
    - dev: eth0
      port: 7777
    client:
      nrf:
      - uri: http://open5gs-nrf-sbi:7777
  pfcp:
    server:
    - dev: eth0
    client:
      upf:
      - address: open5gs-upf-pfcp
  gtpc:
    server:
    - dev: eth0
  gtpu:
    server:
    - dev: eth0
  session:
  - dnn: internet
    subnet: 10.45.0.1/16
  dns:
  - 8.8.8.8
  - 8.8.4.4
  mtu: 1400
  slice:
  - sst: 1
    default_indicator: true
    session:
    - dnn: internet
      type: IPv4
  - sst: 1
    sd: 000000
    default_indicator: true
    session:
    - dnn: internet
      type: IPv4
